# macOS
.DS_Store
**/.DS_Store

# Microsoft Office / LibreOffice — archivos temporales y de bloqueo
~$*.xlsx
~$*.docx
~$*.pptx
.~lock.*

# -------------------------------------------------------------------------
# Outputs generados por Cowork al probar las demos
# Los asistentes sólo necesitan el material de entrada; las salidas las
# genera su propio Cowork al ejecutar los prompts.
# -------------------------------------------------------------------------

# Demo 12 — presentación ejecutiva (output del prompt)
demos/12-revision-herramientas/revision-herramientas-direccion.*

# Demo 14/17 — las subcarpetas analisis/ y ofertas-presentadas/ sólo
# contienen un LEEME.md canónico. Todo lo demás es output de Cowork.
demos/14-licitaciones-2026/analisis/*
!demos/14-licitaciones-2026/analisis/LEEME.md
demos/14-licitaciones-2026/ofertas-presentadas/*
!demos/14-licitaciones-2026/ofertas-presentadas/LEEME.md

# Demo 25 — la subcarpeta informe/ sólo contiene un LEEME.md canónico.
# El informe-gastos.xlsx lo genera Cowork al ejecutar el prompt.
demos/25-informe-gastos/informe/*
!demos/25-informe-gastos/informe/LEEME.md

# Demo 41 — el consolidado valoraciones-Q1-RESUMEN.xlsx lo genera Cowork
# al ejecutar el prompt. Los 4 inputs en valoraciones-Q1/ sí se versionan.
demos/41-consolidar-valoraciones/valoraciones-Q1-RESUMEN.xlsx
